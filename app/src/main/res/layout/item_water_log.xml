<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/health_card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="10dp"
        android:paddingHorizontal="14dp">

        <!-- Icon nước -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:background="@color/health_mint_light"
            android:src="@drawable/ic_health_logo"
            android:contentDescription="Nước uống"
            app:tint="@color/health_mint" />

        <!-- Lượng nước -->
        <TextView
            android:id="@+id/tv_water_amount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:textColor="@color/health_mint"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Thời gian -->
        <TextView
            android:id="@+id/tv_water_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/health_text_secondary"
            android:textSize="12sp" />

        <!-- Xóa -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_water_delete"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:minWidth="0dp"
            android:text="Xóa"
            android:textColor="@color/health_error"
            android:textSize="11sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
