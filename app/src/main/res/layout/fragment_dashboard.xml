<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/health_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_welcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tổng quan sức khỏe"
            android:textColor="@color/health_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Chào bạn, "
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="@color/health_text_secondary"
            android:textSize="15sp" />

        <!-- Nhật ký ăn uống card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:background="@color/health_mint_light"
                    android:src="@drawable/ic_snack"
                    android:contentDescription="Food"
                    app:tint="@color/health_mint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nhật ký ăn uống"
                        android:textColor="@color/health_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Ghi lại món ăn, theo dõi dinh dưỡng mỗi bữa"
                        android:textColor="@color/health_text_secondary"
                        android:textSize="13sp"
                        android:maxLines="2" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_food_diary"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="Mở nhật ký"
                    app:icon="@drawable/ic_arrow_back"
                    app:iconTint="@color/health_mint"
                    app:backgroundTint="@color/health_mint_surface"
                    android:rotation="180" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Vận động & Cân nặng card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:background="@color/health_mint_light"
                    android:contentDescription="Activity"
                    app:srcCompat="@drawable/ic_calendar"
                    app:tint="@color/health_mint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Vận động &amp; Cân nặng"
                        android:textColor="@color/health_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Bước chân, buổi tập, BMI và thống kê tuần"
                        android:textColor="@color/health_text_secondary"
                        android:textSize="13sp"
                        android:maxLines="2" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_activity"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="Mở vận động"
                    app:icon="@drawable/ic_arrow_back"
                    app:iconTint="@color/health_mint"
                    app:backgroundTint="@color/health_mint_surface"
                    android:rotation="180" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Hồ sơ cá nhân card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:background="@color/health_mint_light"
                    android:contentDescription="Profile"
                    app:srcCompat="@drawable/ic_person"
                    app:tint="@color/health_mint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Hồ sơ cá nhân"
                        android:textColor="@color/health_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Thông tin tài khoản, ảnh đại diện, dữ liệu hồ sơ"
                        android:textColor="@color/health_text_secondary"
                        android:textSize="13sp"
                        android:maxLines="2" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_profile"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="Xem hồ sơ"
                    app:icon="@drawable/ic_arrow_back"
                    app:iconTint="@color/health_mint"
                    app:backgroundTint="@color/health_mint_surface"
                    android:rotation="180" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Mục tiêu sức khỏe card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:background="@color/health_mint_light"
                    android:contentDescription="Goals"
                    app:srcCompat="@drawable/ic_ai_chat"
                    app:tint="@color/health_mint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mục tiêu sức khỏe"
                        android:textColor="@color/health_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Cân nặng, calo, bước chân mục tiêu mỗi ngày"
                        android:textColor="@color/health_text_secondary"
                        android:textSize="13sp"
                        android:maxLines="2" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_goals"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="Mở mục tiêu"
                    app:icon="@drawable/ic_arrow_back"
                    app:iconTint="@color/health_mint"
                    app:backgroundTint="@color/health_mint_surface"
                    android:rotation="180" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Biểu đồ calo card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:background="@color/health_mint_light"
                    android:contentDescription="Calorie Chart"
                    app:srcCompat="@drawable/ic_chart"
                    app:tint="@color/health_mint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/chart_title"
                        android:textColor="@color/health_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/chart_desc"
                        android:textColor="@color/health_text_secondary"
                        android:textSize="13sp"
                        android:maxLines="2" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_calorie_chart"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/chart_open"
                    app:icon="@drawable/ic_arrow_back"
                    app:iconTint="@color/health_mint"
                    app:backgroundTint="@color/health_mint_surface"
                    android:rotation="180" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Thực phẩm yêu thích card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:padding="8dp"
                    android:background="@color/health_mint_light"
                    android:contentDescription="Favorites"
                    app:srcCompat="@drawable/ic_heart_filled"
                    app:tint="@color/health_mint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="14dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/fav_title"
                        android:textColor="@color/health_text_primary"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/fav_desc"
                        android:textColor="@color/health_text_secondary"
                        android:textSize="13sp"
                        android:maxLines="2" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_open_favorites"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/fav_title"
                    app:icon="@drawable/ic_arrow_back"
                    app:iconTint="@color/health_mint"
                    app:backgroundTint="@color/health_mint_surface"
                    android:rotation="180" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Logout -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="28dp"
            android:text="Đăng xuất"
            android:textColor="@color/health_error"
            android:textSize="14sp"
            app:icon="@drawable/ic_logout"
            app:iconGravity="textStart"
            app:iconTint="@color/health_error" />
    </LinearLayout>
</ScrollView>
