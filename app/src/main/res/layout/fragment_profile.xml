<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/health_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="36dp">

        <!-- Gradient header -->
        <View
            android:id="@+id/view_header_bg"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:background="@drawable/bg_profile_header"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Back button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="12dp"
            app:icon="@drawable/ic_arrow_back"
            app:iconTint="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Header title -->
        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hồ sơ cá nhân"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toTopOf="@id/btn_back"
            app:layout_constraintBottom_toBottomOf="@id/btn_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Avatar preview (lớn, ở giữa) -->
        <FrameLayout
            android:id="@+id/fl_avatar_container"
            android:layout_width="112dp"
            android:layout_height="112dp"
            android:layout_marginTop="162dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View
                android:layout_width="112dp"
                android:layout_height="112dp"
                android:background="@drawable/bg_avatar_ring" />

            <View
                android:layout_width="106dp"
                android:layout_height="106dp"
                android:layout_gravity="center"
                android:background="#FFFFFFFF" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_avatar"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_avatar_placeholder"
                app:shapeAppearanceOverlay="@style/CircleImageView" />
        </FrameLayout>

        <!-- Tên hiển thị -->
        <TextView
            android:id="@+id/tv_display_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tên người dùng"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/health_text_primary"
            app:layout_constraintTop_toBottomOf="@id/fl_avatar_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Card thông tin -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_info"
            style="@style/HealthCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tv_display_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- Section title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@color/health_green_primary"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin cá nhân"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/health_text_primary" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/health_divider"
                    android:layout_marginBottom="20dp" />

                <!-- Name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_name"
                    style="@style/HealthTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:hint="Họ và tên"
                    app:startIconDrawable="@drawable/ic_person"
                    app:startIconTint="@color/health_green_medium">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName|textCapWords"
                        android:imeOptions="actionNext" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Email (read-only) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_email"
                    style="@style/HealthTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:hint="Email"
                    app:startIconDrawable="@drawable/ic_email"
                    app:startIconTint="@color/health_text_hint">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:enabled="false"
                        android:inputType="textEmailAddress" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- DOB -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_dob"
                    style="@style/HealthTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:hint="Ngày sinh"
                    app:startIconDrawable="@drawable/ic_calendar"
                    app:startIconTint="@color/health_green_medium"
                    app:endIconMode="custom"
                    app:endIconDrawable="@drawable/ic_calendar"
                    app:endIconTint="@color/health_green_medium">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_dob"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:clickable="true"
                        android:hint="dd/MM/yyyy"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Giới tính label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giới tính"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/health_text_primary"
                    android:layout_marginBottom="8dp" />

                <!-- Gender chips -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_gender"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:chipSpacingHorizontal="12dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_male"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Nam"
                        android:textSize="14sp"
                        app:chipBackgroundColor="@color/health_green_light"
                        app:chipStrokeColor="@color/health_green_primary"
                        app:chipStrokeWidth="0dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_female"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Nữ"
                        android:textSize="14sp"
                        app:chipBackgroundColor="@color/health_green_light"
                        app:chipStrokeColor="@color/health_green_primary"
                        app:chipStrokeWidth="0dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_other"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Khác"
                        android:textSize="14sp"
                        app:chipBackgroundColor="@color/health_green_light"
                        app:chipStrokeColor="@color/health_green_primary"
                        app:chipStrokeWidth="0dp" />
                </com.google.android.material.chip.ChipGroup>

                <!-- ─── Avatar Selector ─── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn avatar"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/health_text_primary"
                    android:layout_marginBottom="12dp" />

                <!-- Thông báo khi chọn "Khác" -->
                <TextView
                    android:id="@+id/tv_avatar_hint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vui lòng chọn giới tính Nam hoặc Nữ để chọn avatar"
                    android:textSize="13sp"
                    android:textColor="#F57C00"
                    android:textAlignment="center"
                    android:paddingVertical="8dp"
                    android:visibility="gone" />

                <!-- Avatar Nam -->
                <LinearLayout
                    android:id="@+id/layout_avatar_male"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nam"
                        android:textSize="12sp"
                        android:textColor="@color/health_text_hint"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- male_thin -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:id="@+id/iv_avatar_male_thin"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:src="@drawable/avatar_male_thin"
                                android:padding="4dp"
                                android:background="@drawable/bg_avatar_unselected"
                                android:clickable="true"
                                android:focusable="true" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gầy"
                                android:textSize="11sp"
                                android:textColor="@color/health_text_hint"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- male_normal -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:id="@+id/iv_avatar_male_normal"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:src="@drawable/avatar_male_normal"
                                android:padding="4dp"
                                android:background="@drawable/bg_avatar_unselected"
                                android:clickable="true"
                                android:focusable="true" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bình thường"
                                android:textSize="11sp"
                                android:textColor="@color/health_text_hint"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- male_fat -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:id="@+id/iv_avatar_male_fat"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:src="@drawable/avatar_male_fat"
                                android:padding="4dp"
                                android:background="@drawable/bg_avatar_unselected"
                                android:clickable="true"
                                android:focusable="true" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Béo"
                                android:textSize="11sp"
                                android:textColor="@color/health_text_hint"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

                <!-- Avatar Nữ -->
                <LinearLayout
                    android:id="@+id/layout_avatar_female"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nữ"
                        android:textSize="12sp"
                        android:textColor="@color/health_text_hint"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- female_thin -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:id="@+id/iv_avatar_female_thin"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:src="@drawable/avatar_female_thin"
                                android:padding="4dp"
                                android:background="@drawable/bg_avatar_unselected"
                                android:clickable="true"
                                android:focusable="true" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gầy"
                                android:textSize="11sp"
                                android:textColor="@color/health_text_hint"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- female_normal -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:id="@+id/iv_avatar_female_normal"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:src="@drawable/avatar_female_normal"
                                android:padding="4dp"
                                android:background="@drawable/bg_avatar_unselected"
                                android:clickable="true"
                                android:focusable="true" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bình thường"
                                android:textSize="11sp"
                                android:textColor="@color/health_text_hint"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- female_fat -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <ImageView
                                android:id="@+id/iv_avatar_female_fat"
                                android:layout_width="64dp"
                                android:layout_height="64dp"
                                android:src="@drawable/avatar_female_fat"
                                android:padding="4dp"
                                android:background="@drawable/bg_avatar_unselected"
                                android:clickable="true"
                                android:focusable="true" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Béo"
                                android:textSize="11sp"
                                android:textColor="@color/health_text_hint"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
                <!-- ─── End Avatar Selector ─── -->

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Message -->
        <TextView
            android:id="@+id/tv_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:visibility="gone"
            android:paddingVertical="8dp"
            android:paddingHorizontal="12dp"
            android:background="@drawable/bg_message"
            app:layout_constraintTop_toBottomOf="@id/card_info"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            style="@style/HealthButton.Primary"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="14dp"
            android:text="Lưu thay đổi"
            android:textSize="16sp"
            app:icon="@drawable/ic_person"
            app:iconGravity="textStart"
            app:iconTint="@color/white"
            app:layout_constraintTop_toBottomOf="@id/tv_message"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/btn_save"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>