<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/health_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ══ Gradient Header ══ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@drawable/bg_profile_header">

            <!-- Nút Back -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginTop="16dp"
                android:layout_marginStart="12dp"
                android:contentDescription="Quay lại"
                app:icon="@drawable/ic_arrow_back"
                app:iconTint="@android:color/white"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- Tiêu đề -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giấc ngủ &amp; Nước uống"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="@id/btn_back"
                app:layout_constraintBottom_toBottomOf="@id/btn_back"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Nhật ký giấc ngủ và theo dõi nước uống"
                android:textColor="#8ECFB0"
                android:textSize="13sp"
                app:layout_constraintTop_toBottomOf="@id/btn_back"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ══ Nội dung ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

        <!-- Error & Loading -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/health_error"
            android:textSize="13sp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <!-- ══ Ghi nhật ký giấc ngủ ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/health_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ghi nhật ký giấc ngủ"
                    android:textColor="@color/health_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Chọn giờ ngủ / thức -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pick_bed_time"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Chọn giờ ngủ"
                        android:textColor="@color/health_mint"
                        app:cornerRadius="24dp"
                        app:strokeColor="@color/health_mint" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_pick_wake_time"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:text="Chọn giờ thức"
                        android:textColor="@color/health_mint"
                        app:cornerRadius="24dp"
                        app:strokeColor="@color/health_mint" />
                </LinearLayout>

                <!-- Đánh giá chất lượng -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Chất lượng giấc ngủ"
                    android:textColor="@color/health_text_secondary"
                    android:textSize="13sp" />

                <Spinner
                    android:id="@+id/spinner_quality"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_input_filled"
                    android:padding="12dp" />

                <!-- Ghi chú -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/HealthTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Ghi chú (tuỳ chọn)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_sleep_note"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapSentences|textMultiLine"
                        android:maxLines="3" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_sleep_log"
                    style="@style/HealthButton.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="16dp"
                    android:text="Lưu nhật ký giấc ngủ"
                    app:cornerRadius="25dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Biểu đồ giấc ngủ 7 ngày ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/health_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Phân tích 7 ngày gần nhất"
                    android:textColor="@color/health_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_sleep_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Chưa có dữ liệu."
                    android:textColor="@color/health_text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_sleep_warning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:textColor="@color/health_warning"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <com.github.mikephil.charting.charts.LineChart
                    android:id="@+id/line_chart_sleep"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginTop="14dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Theo dõi nước uống ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/health_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nước uống hôm nay"
                    android:textColor="@color/health_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Tổng & tiến trình -->
                <TextView
                    android:id="@+id/tv_water_total"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="0 ml / 2000 ml"
                    android:textColor="@color/health_mint"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <ProgressBar
                    android:id="@+id/progress_water"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="12dp"
                    android:layout_marginTop="10dp"
                    android:max="100"
                    android:progress="0"
                    android:progressDrawable="@drawable/bg_circle_progress" />

                <!-- Nút nhanh -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Thêm nhanh"
                    android:textColor="@color/health_text_secondary"
                    android:textSize="13sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_water_250"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="250 ml"
                        android:textColor="@color/health_mint"
                        app:cornerRadius="22dp"
                        app:strokeColor="@color/health_mint" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_water_350"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginHorizontal="8dp"
                        android:layout_weight="1"
                        android:text="350 ml"
                        android:textColor="@color/health_mint"
                        app:cornerRadius="22dp"
                        app:strokeColor="@color/health_mint" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_water_500"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="500 ml"
                        android:textColor="@color/health_mint"
                        app:cornerRadius="22dp"
                        app:strokeColor="@color/health_mint" />
                </LinearLayout>

                <!-- Nhập tuỳ chỉnh -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/HealthTextInputLayout"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Nhập ml...">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_water_amount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_add_water"
                        style="@style/HealthButton.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="50dp"
                        android:layout_marginStart="10dp"
                        android:text="Thêm"
                        app:cornerRadius="25dp" />
                </LinearLayout>

                <!-- Danh sách lần uống nước hôm nay -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Lần uống hôm nay"
                    android:textColor="@color/health_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_empty_water"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Chưa có lần uống nước nào hôm nay."
                    android:textColor="@color/health_text_hint"
                    android:textSize="13sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_water_logs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Nhắc nhở ══ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@color/health_card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nhắc nhở"
                    android:textColor="@color/health_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_set_water_reminder"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="14dp"
                    android:text="Đặt nhắc uống nước mỗi 2 tiếng"
                    android:textColor="@color/health_mint"
                    app:cornerRadius="25dp"
                    app:strokeColor="@color/health_mint" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_set_sleep_reminder"
                    style="@style/HealthButton.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="10dp"
                    android:text="Đặt nhắc đi ngủ"
                    app:cornerRadius="25dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Nhắc đi ngủ sẽ dùng giờ bạn đã chọn ở phần nhật ký (hoặc 22:00 mặc định)."
                    android:textColor="@color/health_text_hint"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ══ Lịch sử giấc ngủ ══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Lịch sử giấc ngủ"
            android:textColor="@color/health_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_empty_sleep"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Chưa có bản ghi giấc ngủ nào."
            android:textColor="@color/health_text_secondary"
            android:textSize="14sp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_sleep_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:nestedScrollingEnabled="false" />

        </LinearLayout><!-- end nội dung -->
    </LinearLayout><!-- end outer -->
</androidx.core.widget.NestedScrollView>
