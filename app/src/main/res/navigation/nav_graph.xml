<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.moblie_app.ui.auth.LoginFragment"
        android:label="Đăng nhập">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.moblie_app.ui.auth.RegisterFragment"
        android:label="Đăng ký">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_register_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.moblie_app.ui.dashboard.DashboardFragment"
        android:label="Tổng quan">
        <action
            android:id="@+id/action_dashboard_to_activity"
            app:destination="@id/activityFragment" />
        <action
            android:id="@+id/action_dashboard_to_profile"
            app:destination="@id/profileFragment" />
        <action
            android:id="@+id/action_dashboard_to_goals"
            app:destination="@id/healthGoalsFragment" />
        <action
            android:id="@+id/action_dashboard_to_food_diary"
            app:destination="@id/foodDiaryFragment" />
        <action
            android:id="@+id/action_dashboard_to_calorie_chart"
            app:destination="@id/calorieChartFragment" />
        <action
            android:id="@+id/action_dashboard_to_search_food"
            app:destination="@id/searchFoodFragment" />
    </fragment>

    <fragment
        android:id="@+id/foodDiaryFragment"
        android:name="com.example.moblie_app.ui.diary.FoodDiaryFragment"
        android:label="Nhật ký ăn uống">
        <action
            android:id="@+id/action_foodDiary_to_searchFood"
            app:destination="@id/searchFoodFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFoodFragment"
        android:name="com.example.moblie_app.ui.search.SearchFoodFragment"
        android:label="Tìm kiếm món ăn" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.moblie_app.ui.profile.ProfileFragment"
        android:label="Hồ sơ cá nhân">
        <action
            android:id="@+id/action_profile_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/dashboardFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_profile_to_goals"
            app:destination="@id/healthGoalsFragment" />
    </fragment>

    <fragment
        android:id="@+id/healthGoalsFragment"
        android:name="com.example.moblie_app.ui.goals.HealthGoalsFragment"
        android:label="Mục tiêu sức khỏe">
        <action
            android:id="@+id/action_goals_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/dashboardFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/activityFragment"
        android:name="com.example.moblie_app.ui.activity.ActivityFragment"
        android:label="Vận động &amp; Cân nặng" />

    <fragment
        android:id="@+id/calorieChartFragment"
        android:name="com.example.moblie_app.ui.caloriechart.CalorieChartFragment"
        android:label="@string/chart_title" />

    <fragment
        android:id="@+id/aiChatFragment"
        android:name="com.example.moblie_app.ui.aichat.AiChatFragment"
        android:label="AI tư vấn sức khỏe" />

    <!-- Action toàn cục: cho phép mở AI Chat từ bất kỳ màn hình nào (FAB ở MainActivity) -->
    <action
        android:id="@+id/action_global_aiChatFragment"
        app:destination="@id/aiChatFragment" />

</navigation>
