<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.moblie_app.ui.auth.LoginFragment"
        android:label="Đăng nhập">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.moblie_app.ui.auth.RegisterFragment"
        android:label="Đăng ký">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_register_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.moblie_app.ui.dashboard.DashboardFragment"
        android:label="Tổng quan">
        <action
            android:id="@+id/action_dashboard_to_activity"
            app:destination="@id/activityFragment" />
    </fragment>

    <fragment
        android:id="@+id/activityFragment"
        android:name="com.example.moblie_app.ui.activity.ActivityFragment"
        android:label="Vận động &amp; Cân nặng" />

</navigation>
