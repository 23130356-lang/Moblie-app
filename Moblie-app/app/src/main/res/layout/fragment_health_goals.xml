<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/health_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="36dp">

        <!-- Gradient header -->
        <View
            android:id="@+id/view_header_bg"
            android:layout_width="0dp"
            android:layout_height="180dp"
            android:background="@drawable/bg_profile_header"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Back button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_back"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="12dp"
            app:icon="@drawable/ic_arrow_back"
            app:iconTint="@android:color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Header title -->
        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mục tiêu sức khỏe"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:layout_constraintTop_toTopOf="@id/btn_back"
            app:layout_constraintBottom_toBottomOf="@id/btn_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Header subtitle -->
        <TextView
            android:id="@+id/tv_header_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Thiết lập để theo dõi tiến trình mỗi ngày"
            android:textSize="13sp"
            android:textColor="#8ECFB0"
            app:layout_constraintTop_toBottomOf="@id/btn_back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ===== CARD: Cân nặng ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_weight"
            style="@style/HealthCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="148dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Card title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@color/health_green_primary"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⚖️  Cân nặng mục tiêu"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/health_text_primary" />

                    <!-- Current value badge -->
                    <TextView
                        android:id="@+id/tv_weight_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="65 kg"
                        android:textSize="13sp"
                        android:textColor="@color/health_green_medium"
                        android:textStyle="bold"
                        android:background="@color/health_green_light"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Slider -->
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_weight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="30"
                    android:valueTo="150"
                    android:value="65"
                    android:stepSize="0.5"
                    app:thumbColor="@color/health_green_primary"
                    app:trackColorActive="@color/health_green_primary"
                    app:trackColorInactive="@color/health_divider"
                    app:labelBehavior="floating" />

                <!-- Min / Max labels -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="30 kg"
                        android:textSize="11sp"
                        android:textColor="@color/health_text_hint" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="150 kg"
                        android:textSize="11sp"
                        android:textColor="@color/health_text_hint" />
                </LinearLayout>

                <!-- Manual input -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_weight"
                    style="@style/HealthTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Nhập chính xác (kg)"
                    app:suffixText="kg">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_weight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionNext" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== CARD: Calo ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_calories"
            style="@style/HealthCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/card_weight"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@color/health_warning"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔥  Calo mỗi ngày"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/health_text_primary" />

                    <TextView
                        android:id="@+id/tv_calories_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2000 kcal"
                        android:textSize="13sp"
                        android:textColor="@color/health_warning"
                        android:textStyle="bold"
                        android:background="#FFF5E6"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- Quick preset chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_calories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_cal_1200"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1200 kcal" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_cal_1500"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1500 kcal" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_cal_2000"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2000 kcal"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_cal_2500"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2500 kcal" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_cal_3000"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3000 kcal" />

                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_calories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="800"
                    android:valueTo="4000"
                    android:value="2000"
                    android:stepSize="50"
                    app:thumbColor="@color/health_warning"
                    app:trackColorActive="@color/health_warning"
                    app:trackColorInactive="@color/health_divider"
                    app:labelBehavior="floating" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="800 kcal"
                        android:textSize="11sp"
                        android:textColor="@color/health_text_hint" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4000 kcal"
                        android:textSize="11sp"
                        android:textColor="@color/health_text_hint" />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_calories"
                    style="@style/HealthTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Nhập chính xác (kcal)"
                    app:suffixText="kcal">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_calories"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:imeOptions="actionNext" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== CARD: Số bước chân ===== -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_steps"
            style="@style/HealthCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/card_calories"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="#3B82F6"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="👟  Số bước chân mỗi ngày"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/health_text_primary" />

                    <TextView
                        android:id="@+id/tv_steps_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8.000"
                        android:textSize="13sp"
                        android:textColor="#3B82F6"
                        android:textStyle="bold"
                        android:background="#EFF6FF"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <!-- Preset chips -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="14dp">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_steps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_steps_5000"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5.000" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_steps_7000"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7.000" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_steps_8000"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8.000"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_steps_10000"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10.000" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_steps_15000"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15.000" />

                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>

                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_steps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1000"
                    android:valueTo="30000"
                    android:value="8000"
                    android:stepSize="500"
                    app:thumbColor="#3B82F6"
                    app:trackColorActive="#3B82F6"
                    app:trackColorInactive="@color/health_divider"
                    app:labelBehavior="floating" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="1.000"
                        android:textSize="11sp"
                        android:textColor="@color/health_text_hint" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30.000"
                        android:textSize="11sp"
                        android:textColor="@color/health_text_hint" />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_steps"
                    style="@style/HealthTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:hint="Nhập chính xác"
                    app:suffixText="bước">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_steps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:imeOptions="actionDone" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Message -->
        <TextView
            android:id="@+id/tv_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:textSize="13sp"
            android:textAlignment="center"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/card_steps"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Save button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            style="@style/HealthButton.Primary"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="14dp"
            android:text="Lưu mục tiêu"
            app:layout_constraintTop_toBottomOf="@id/tv_message"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/btn_save"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
